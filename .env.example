# Copy to .env and edit as needed: cp .env.example .env

# Host ports
HTTP_PORT=3000
HTTPS_PORT=3001

# Host path to mount at /data inside the container
DATA_DIR=./data

# User/group inside the container — set to match `id -u` / `id -g`
# so files written to /data are owned by you, not root
PUID=1000
PGID=1000

TZ=America/New_York
